{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and credentials",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "password": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" }
      },
      "required": ["id", "name", "password"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" },
        "type": { "type": "string", "enum": ["text", "image", "video", "audio", "sticker"] },
        "mediaUrl": { "type": "string" }
      },
      "required": ["from", "to", "timestamp", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Global chat messages"
    },
    "/typing/{typingId}": {
      "schema": "object",
      "description": "Real-time typing indicators"
    }
  }
}
